---
import "../styles/global.css";
---

<html lang="de" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Netzwerk-Leitfaden | Cisco Lab</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code&family=Inter:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="text-slate-300 font-sans
      bg-[#020617]
      selection:bg-blue-500/30"
  >
    <div class="flex">
      <aside
        class="hidden overflow-y-auto
          h-screen w-80
          p-8
          bg-black/40
          border-r border-white/5
          fixed
          lg:block"
      >
        <div
          class="mb-10
            text-blue-500 font-black text-2xl tracking-tighter
            italic uppercase"
        >
          CISCO<span class="text-white
              not-italic">_LAB</span>
        </div>

        <nav
          class="space-y-4
            text-xs font-bold tracking-widest text-white/90
            uppercase"
        >
          <a
            href="#escenario"
            class="block
              hover:text-blue-400 transition"
            >00. Szenario</a
          >
          <a
            href="#diseno"
            class="block
              hover:text-blue-400 transition"
            >01. Design & IPs</a
          >
          <a
            href="#seguridad"
            class="block
              hover:text-blue-400 transition"
            >02. Sicherheit</a
          >
          <a
            href="#acceso"
            class="block
              hover:text-blue-400 transition"
            >03. Access-Switch (L2)</a
          >
          <a
            href="#nucleo"
            class="block
              hover:text-blue-400 transition"
            >04. Core-Switch (L3)</a
          >
          <a
            href="#dinamico"
            class="block
              hover:text-blue-400 transitio"
            >05. Dynamisches Routing</a
          >
          <a
            href="#estatico"
            class="block
              hover:text-blue-400 transitio"
            >06. Statisches Routing</a
          >
          <a
            href="#routers"
            class="block
              hover:text-blue-400 transitio"
            >07. Router/NAT</a
          >
          <a
            href="#wlan"
            class="block
              hover:text-blue-400 transitio"
            >08. Wireless</a
          >
          <a
            href="#laptops"
            class="block
              hover:text-blue-400 transitio"
            >09. Laptops</a
          >

          <div class="pt-4">
            <a
              href="#verificacion"
              class="block
                  p-2
                  text-blue-400 text-center tracking-tighter
                  border border-blue-400/20
                  rounded hover:bg-blue-400/10 transition uppercase"
            >
              Verifizierung
            </a>
          </div>
        </nav>
      </aside>

      <main
        class="max-w-7xl w-full
          p-8
          md:p-16
          lg:ml-72"
      >
        <header class="mb-24">
          <h1
            class="mb-6
              text-6xl font-black text-white tracking-tighter leading-none
              md:text-8xl"
          >
            Netzwerk <span class="text-blue-500">Leitfaden</span>
          </h1>
          <p class="max-w-3xl text-xl text-slate-400 italic">
            Vollständige Schritt-für-Schritt-Konfiguration für Gebäude West und Ost. Globales Netz: 
            <span class="text-blue-400 font-mono">10.G.V.X /8</span>
          </p>
        </header>

        <section id="escenario" class="mb-32">
          <h2
            class="mb-8 pl-4
              text-3xl font-bold text-white
              border-l-4 border-blue-500
              uppercase"
          >
            00. Projektszenario (Firma ABC)
          </h2>
          
          <div class="grid gap-6 md:grid-cols-2">
            <div class="p-8 bg-slate-900/50 rounded-3xl border border-white/5 shadow-2xl">
              <h3 class="mb-4 text-lg font-bold text-blue-400 uppercase italic">Kundenanforderungen:</h3>
              <ul class="space-y-3 text-sm text-slate-400 italic">
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Infrastruktur:</strong> 200 Mitarbeiter verteilt auf zwei Gebäude (West/Ost) mit 2 Funktionsebenen (Etage 4 und 6).</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Design:</strong> <span class="text-white font-mono">Collapsed Core</span> Architektur zur Unterstützung künftiger Erweiterungen (Etage 5 und Gebäude 3).</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Konnektivität:</strong> ISP-Redundanz über 2 Router und virtuelle Gateways mittels <span class="text-white font-mono">HSRP</span>.</span>
                </li>
              </ul>
            </div>

            <div class="p-8 bg-blue-900/10 rounded-3xl border border-blue-500/20 shadow-2xl">
              <h3 class="mb-4 text-lg font-bold text-blue-400 uppercase italic">Technische Spezifikationen:</h3>
              <ul class="space-y-3 text-sm text-slate-400 italic">
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Normung:</strong> Zertifizierte strukturierte Verkabelung nach europäischer Norm <span class="text-white">EN50173</span>.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Provisorisches WAN:</strong> Internet-Ausgangstest im Bereich <span class="text-white font-mono">192.168.18.0 /24</span> konfiguriert.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Sicherheit:</strong> Segmentierung in 10 Zonen über VLANs und SSH-Zugriffskontrolle.</span>
                </li>
              </ul>
            </div>
          </div>
        </section>

        <section id="diseno" class="mb-32">
          <h2
            class="mb-8 pl-4
              text-3xl font-bold text-white
              border-l-4 border-blue-500
              uppercase"
          >
            01. Physisches Design und Adressierung
          </h2>

          <div
            class="grid grid-cols-1
              mb-8
              gap-4
              md:grid-cols-2
              lg:grid-cols-4"
          >
            <div
              class="p-5
                bg-slate-900/50
                rounded-xl border border-white/5"
            >
              <p
                class="mb-2
                  text-[12px] text-blue-400 font-mono
                  uppercase"
              >
                VLAN 08
              </p>
              <p class="font-bold text-white
                  uppercase italic">
                Management
              </p>
            </div>
            <div
              class="p-5
                bg-red-900/10
                rounded-xl border border-red-500/20"
            >
              <p
                class="mb-2
                  text-[12px] text-red-400 font-mono
                  uppercase"
              >
                VLAN 12 / 13
              </p>
              <p
                class="font-bold text-red-100
                  uppercase italic"
              >
                Gebäude West
              </p>
            </div>
            <div
              class="p-5
                bg-pink-900/10
                rounded-xl border border-pink-500/20"
            >
              <p
                class="mb-2
                  text-[12px] text-pink-400 font-mono
                  uppercase"
              >
                VLAN 22 / 23
              </p>
              <p
                class="font-bold text-pink-100
                  uppercase italic"
              >
                Gebäude Ost
              </p>
            </div>
            <div
              class="p-5
                bg-emerald-900/10
                rounded-xl border border-emerald-500/20"
            >
              <p
                class="mb-2
                  text-[12px] text-emerald-400 font-mono
                  uppercase"
              >
                VLAN 99
              </p>
              <p
                class="font-bold text-emerald-100
                  uppercase italic"
              >
                Server
              </p>
            </div>
          </div>

          <div
            class="p-8
              bg-blue-900/10
              rounded-3xl border border-blue-500/20"
          >
            <h3
              class="mb-4
                text-lg font-bold text-blue-400
                uppercase italic"
            >
              Core-Spezifikationen:
            </h3>
            <ul
              class="space-y-3
                text-sm leading-relaxed text-slate-400
                italic"
            >
              <li class="flex
                  items-center gap-3">
                <span
                  class="w-2 h-2
                    bg-blue-500
                    rounded-full"
                ></span>
                <strong>Core-Ports:</strong> Exklusive Nutzung von <span
                  class="text-white font-mono">GigabitEthernet</span
                > für die Verbindung zwischen 3560 Switches und Routern.
              </li>
              <li class="flex
                  items-center gap-3">
                <span
                  class="w-2 h-2
                    bg-blue-500
                    rounded-full"
                ></span>
                <strong>Access-Ports:</strong> Nutzung von <span
                  class="text-white font-mono">FastEthernet</span
                > für Laptops und 2960 Switches.
              </li>
            </ul>
          </div>
        </section>
        

        <section id="seguridad" class="mb-32">
          <h2
            class="mb-8 pl-4
              text-3xl font-bold text-white
              border-l-4 border-blue-500
              uppercase"
          >
            02. Basiskonfiguration und Sicherheit (Alle)
          </h2>
          <div
            class="overflow-hidden
              font-mono text-sm
              bg-[#0a0f1e]
              rounded-2xl border border-white/10
              shadow-2xl"
          >
            <div
              class="flex
                px-4 py-2
                bg-white/5
                border-b border-white/10
                justify-between"
            >
              <span
                class="text-xs text-slate-500 tracking-tighter
                  uppercase italic"
                >IOS CLI — Security & VTY Setup</span
              >
              <div class="flex
                  gap-2">
                <div
                  class="w-2 h-2
                    bg-red-500/50
                    rounded-full"
                >
                </div>
                <div
                  class="w-2 h-2
                    bg-green-500/50
                    rounded-full"
                >
                </div>
              </div>
            </div>
            <div class="overflow-x-auto p-8 text-white-300 leading-relaxed">
              <p>enable</p>
              <p>configure terminal</p>
              <p>hostname [Device_Name]</p>
              <p>ip domain-name lab.test</p>
              <p>no ip domain-lookup</p>
              <br />
              <p>username cisco privilege 15 secret cisco</p>
              <p>enable secret cisco</p>
              <p>service password-encryption</p>
              <br />
              <p>banner motd # ZUTRITT NUR FÜR BEFUGTE PERSONEN #</p>
              <br />
              <p>access-list 10 permit 10.0.8.0 0.0.0.255</p>
              <br />
              <p>line console 0</p>
              <p class="pl-4">exec-timeout 0 0</p> <p class="pl-4">logging synchronous</p>
              <p class="pl-4">login</p>
              <p class="pl-4">exit</p>
              <br />
              <p>line vty 0 15</p>
              <p class="pl-4">exec-timeout 0 0</p>
              <p class="pl-4">login local</p>
              <p class="pl-4">transport input ssh</p>
              <p class="pl-4">access-class 10 in</p>
              <p class="pl-4">exit</p>
              <br />
              <p>logging buffered 8192</p>
              <p class="text-orange-400/80 italic text-[13px] mb-1">
              // Hinweis: In Gebäude Ost die Reihenfolge umkehren (Zuerst Server Ost, dann West)
              </p>
              <p>logging host [IP West-Server]</p> 
              <p>logging host [IP Ost-Server]</p> 
              <p>logging trap debugging</p>
              <p>logging source-interface vlan 8</p>
              <p class="text-orange-400/80 italic text-[13px] mb-1">// Zeitsynchronisierung (Server West und Ost)</p>
              <p>ntp server [IP West-Server]</p>
              <p>ntp server [IP Ost-Server]</p>
              <p>clock timezone CET 1</p>
              <p>crypto key generate rsa</p>
              <p>ip ssh version 2</p>
            </div>
          </div>
        </section>

        <section id="acceso" class="mb-32">
          <h2
            class="mb-10 pl-4
              text-3xl font-bold text-white tracking-tighter
              border-l-4 border-blue-500
              uppercase"
          >
            03. Konfiguration der Access-Switches (2960 - L2)
          </h2>

          <div class="grid
              gap-8
              lg:grid-cols-2">
            <div
              class="p-8
                bg-slate-900/50
                rounded-3xl border border-white/5
                shadow-2xl"
            >
              <h3
                class="mb-6
                  text-xl font-bold text-blue-500
                  uppercase"
              >
                SWITCH EV-L <span class="text-white font-medium">(WEST)</span>
              </h3>

              <div
                class="space-y-8
                  font-mono text-[12px] leading-relaxed"
              >
                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // VLAN-Erstellung
                  </p>
                  <div
                    class="overflow-x-auto
                      p-4
                      leading-relaxed
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>vlan 8 name Management</p>
                    <p>vlan 13 name West_Azul</p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Port-Sicherheit
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>interface range fa0/1 - 24</p>
                    <p class="pl-4">switchport mode access</p>
                    <p class="pl-4">switchport access vlan 13</p>
                    <p class="pl-4">spanning-tree portfast</p>
                    <p class="pl-4">switchport port-security</p>
                    <p class="pl-4">switchport port-security maximum 2</p>
                    <p class="pl-4">
                      switchport port-security mac-address sticky
                    </p>
                    <p class="pl-4">
                      switchport port-security violation shutdown
                    </p>
                    <p class="pl-4">spanning-tree bpduguard enable</p>
                    <p>exit</p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Trunk-Links und Management
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>interface gig0/1</p>
                    <p class="pl-4">description Hauptlink_zu_GV-L</p>
                    <p class="pl-4">switchport mode trunk</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p>interface gig0/2</p>
                    <p class="pl-4">description Hauptlink_zu_GV-R</p>
                    <p class="pl-4">switchport mode trunk</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p>interface vlan 8</p>
                    <p class="pl-4">ip address 10.0.8.11 255.255.255.0</p>
                    <p class="pl-4">no shut</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p class="font-bold">ip default-gateway 10.0.8.1</p>
                  </div>
                </div>
              </div>
            </div>

            <div
              class="p-8
                bg-slate-900/50
                rounded-3xl border border-white/5
                shadow-2xl"
            >
              <h3
                class="mb-6
                  text-xl font-bold text-blue-500
                  uppercase"
              >
                SWITCH EV-R <span
                  class="text-white font-normal
                    not-italic"
                  >(OST)</span
                >
              </h3>

              <div
                class="space-y-8
                  font-mono text-[12px] leading-relaxed"
              >
                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // VLAN-Erstellung
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>vlan 8 name Management</p>
                    <p>vlan 23 name Ost_Lila</p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Port-Sicherheit
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>interface range fa0/1 - 24</p>
                    <p class="pl-4">switchport mode access</p>
                    <p class="pl-4">switchport access vlan 23</p>
                    <p class="pl-4">spanning-tree portfast</p>
                    <p class="pl-4">switchport port-security</p>
                    <p class="pl-4">switchport port-security maximum 2</p>
                    <p class="pl-4">
                      switchport port-security mac-address sticky
                    </p>
                    <p class="pl-4">
                      switchport port-security violation shutdown
                    </p>
                    <p class="pl-4">spanning-tree bpduguard enable</p>
                    <p>exit</p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Trunk-Links und Management
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>interface gig0/1</p>
                    <p class="pl-4">description Hauptlink_zu_GV-R</p>
                    <p class="pl-4">switchport mode trunk</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p>interface gig0/2</p>
                    <p class="pl-4">description Hauptlink_zu_GV-L</p>
                    <p class="pl-4">switchport mode trunk</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p>interface vlan 8</p>
                    <p class="pl-4">ip address 10.0.8.22 255.255.255.0</p>
                    <p class="pl-4">no shut</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p class="font-bold">ip default-gateway 10.0.8.1</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section id="nucleo" class="mb-32">
          <h2
            class="mb-10 pl-4
              text-3xl font-bold text-white tracking-tighter
              border-l-4 border-blue-500
              uppercase"
          >
            04. Core-Konfiguration (3560 - Layer 3)
          </h2>

          <div class="grid
              gap-8
              lg:grid-cols-2">
            <div
              class="p-8
                bg-slate-900/50
                rounded-3xl border border-white/5
                shadow-2xl"
            >
              <h3
                class="mb-6
                  text-xl font-bold text-blue-500
                  uppercase"
              >
                SWITCH GV-L <span class="text-white font-medium">(WEST)</span>
              </h3>

              <div
                class="space-y-8
                  font-mono text-[12px] leading-relaxed"
              >
                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // L3-Aktivierung und VLANs
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>ip routing</p>
                    <p>vlan 8 name Management</p>
                    <p
                      class="text-slate-500 font-sans
                        italic"
                    >
                      // Ebenfalls vlan 12, 13, 22, 23, 99 erstellen
                    </p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Gateways (SVIs) und HSRP (Hot Standby Router Protocol)
                  </p>
                  <div
                    class="p-4 space-y-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <div>
                      <p class="text-slate-500
                          italic">
                        // VLAN 12 & 13 (Haupt-VLANs West - G=1)
                      </p>
                      <p class="text-red-400">interface vlan 12</p>
                      <p class="pl-4">ip address 10.1.12.2 255.255.255.0</p>
                      <p class="pl-4">standby 12 ip 10.1.12.1</p>
                      <p class="pl-4">standby 12 priority 110</p>
                      <p class="pl-4">standby 12 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>
                      <br />
                      <p class="text-red-400">interface vlan 13</p>
                      <p class="pl-4">ip address 10.1.13.2 255.255.255.0</p>
                      <p class="pl-4">standby 13 ip 10.1.13.1</p>
                      <p class="pl-4">standby 13 priority 110</p>
                      <p class="pl-4">standby 13 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>
                    </div>
                    <div>
                      <p class="text-slate-500 italic"> // VLAN 22 & 23 (Backup Ost)</p>
                      <p class="text-pink-400">interface vlan 22</p>
                      <p class="pl-4">ip address 10.2.22.3 255.255.255.0</p>
                      <p class="pl-4">standby 22 ip 10.2.22.1</p>
                      <p class="pl-4">standby 22 priority 100</p>
                      <p class="pl-4">standby 22 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>
                      <br />
                      <p class="text-pink-400">interface vlan 23</p>
                      <p class="pl-4">ip address 10.2.23.3 255.255.255.0</p>
                      <p class="pl-4">standby 23 ip 10.2.23.1</p>
                      <p class="pl-4">standby 23 priority 100</p>
                      <p class="pl-4">standby 23 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>                      
                      <br />
                      <p class="text-slate-500 italic"> // Internes Management-Netz</p>
                      <p class="text-blue-400">interface vlan 8 <span class="text-black/40">h</span></p>
                      <p class="pl-4">ip address 10.0.8.2 255.255.255.0</p>
                      <p class="pl-4">standby 8 ip 10.0.8.1</p>
                      <p class="pl-4">standby 8 priority 110</p>
                      <p class="pl-4">standby 8 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>
                      <br />
                      <p class="text-slate-500 italic"> // Internes Server-Netz</p>
                      <p class="text-emerald-400">interface vlan 99</p>
                      <p class="pl-4 italic">ip address 10.0.99.2 255.255.255.0</p>
                      <p class="pl-4">standby 99 ip 10.0.99.1</p>
