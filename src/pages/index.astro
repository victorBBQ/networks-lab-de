---
import "../styles/global.css";
---

<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Guía de Redes | Cisco Lab</title>
    <link
      href="https://fonts.googleapis.com/css2?family=Fira+Code&family=Inter:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body
    class="text-slate-300 font-sans
      bg-[#020617]
      selection:bg-blue-500/30"
  >
    <div class="flex">
      <aside
        class="hidden overflow-y-auto
          h-screen w-80
          p-8
          bg-black/40
          border-r border-white/5
          fixed
          lg:block"
      >
        <div
          class="mb-10
            text-blue-500 font-black text-2xl tracking-tighter
            italic uppercase"
        >
          CISCO<span class="text-white
              not-italic">_LAB</span>
        </div>

        <nav
          class="space-y-4
            text-xs font-bold tracking-widest text-white/90
            uppercase"
        >
          <a
            href="#escenario"
            class="block
              hover:text-blue-400 transition"
            >00. Escenario</a
          >
          <a
            href="#diseno"
            class="block
              hover:text-blue-400 transition"
            >01. Diseño e IPs</a
          >
          <a
            href="#seguridad"
            class="block
              hover:text-blue-400 transition"
            >02. Seguridad</a
          >
          <a
            href="#acceso"
            class="block
              hover:text-blue-400 transition"
            >03. Acceso L2</a
          >
          <a
            href="#nucleo"
            class="block
              hover:text-blue-400 transition"
            >04. Núcleo L3</a
          >
          <a
            href="#dinamico"
            class="block
              hover:text-blue-400 transitio"
            >05. Enrutamiento Dinámico</a
          >
          <a
            href="#estatico"
            class="block
              hover:text-blue-400 transitio"
            >06. Enrutamiento Estático</a
          >
          <a
            href="#routers"
            class="block
              hover:text-blue-400 transitio"
            >07. Routers/NAT</a
          >
          <a
            href="#wlan"
            class="block
              hover:text-blue-400 transitio"
            >08. Wireless</a
          >
          <a
            href="#laptops"
            class="block
              hover:text-blue-400 transitio"
            >09. Laptops</a
          >

          <div class="pt-4">
            <a
              href="#verificacion"
              class="block
                  p-2
                  text-blue-400 text-center tracking-tighter
                  border border-blue-400/20
                  rounded hover:bg-blue-400/10 transition uppercase"
            >
              Verificación
            </a>
          </div>
        </nav>
      </aside>

      <main
        class="max-w-7xl w-full
          p-8
          md:p-16
          lg:ml-72"
      >
        <header class="mb-24">
          <h1
            class="mb-6
              text-6xl font-black text-white tracking-tighter leading-none
              md:text-8xl"
          >
            Guía de <span class="text-blue-500">Redes</span>
          </h1>
          <p
            class="max-w-2xl
              text-xl text-slate-400
              italic"
          >
            Configuración integral paso a paso para edificios West y Ost. Red
            Global: <span class="text-blue-400 font-mono">10.G.V.X /8</span>
          </p>
        </header>

        <section id="escenario" class="mb-32">
          <h2
            class="mb-8 pl-4
              text-3xl font-bold text-white
              border-l-4 border-blue-500
              uppercase"
          >
            00. Escenario del Proyecto (Firma ABC)
          </h2>
          
          <div class="grid gap-6 md:grid-cols-2">
            <div class="p-8 bg-slate-900/50 rounded-3xl border border-white/5 shadow-2xl">
              <h3 class="mb-4 text-lg font-bold text-blue-400 uppercase italic">Requerimientos del Cliente:</h3>
              <ul class="space-y-3 text-sm text-slate-400 italic">
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Infraestructura:</strong> 200 empleados distribuidos en dos edificios (West/Ost) con 2 plantas funcionales (Pisos 4 y 6).</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Diseño:</strong> Arquitectura <span class="text-white font-mono">Collapsed Core</span> para soportar expansión futura (Piso 5 y Edificio 3).</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Conectividad:</strong> Redundancia ISP mediante 2 routers y Gateways virtuales vía <span class="text-white font-mono">HSRP</span>.</span>
                </li>
              </ul>
            </div>

            <div class="p-8 bg-blue-900/10 rounded-3xl border border-blue-500/20 shadow-2xl">
              <h3 class="mb-4 text-lg font-bold text-blue-400 uppercase italic">Especificaciones Técnicas:</h3>
              <ul class="space-y-3 text-sm text-slate-400 italic">
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Normativa:</strong> Cableado estructurado certificado bajo la norma europea <span class="text-white">EN50173</span>.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>WAN Provisoria:</strong> Testing de salida a Internet configurado en el rango <span class="text-white font-mono">192.168.18.0 /24</span>.</span>
                </li>
                <li class="flex items-start gap-3">
                  <span class="text-blue-500 font-bold">»</span>
                  <span><strong>Seguridad:</strong> Segmentación en 10 zonas mediante VLANs y control de acceso SSH.</span>
                </li>
              </ul>
            </div>
          </div>
        </section>

        <section id="diseno" class="mb-32">
          <h2
            class="mb-8 pl-4
              text-3xl font-bold text-white
              border-l-4 border-blue-500
              uppercase"
          >
            01. Diseño Físico y Direccionamiento
          </h2>

          <div
            class="grid grid-cols-1
              mb-8
              gap-4
              md:grid-cols-2
              lg:grid-cols-4"
          >
            <div
              class="p-5
                bg-slate-900/50
                rounded-xl border border-white/5"
            >
              <p
                class="mb-2
                  text-[12px] text-blue-400 font-mono
                  uppercase"
              >
                VLAN 08
              </p>
              <p class="font-bold text-white
                  uppercase italic">
                Management
              </p>
            </div>
            <div
              class="p-5
                bg-red-900/10
                rounded-xl border border-red-500/20"
            >
              <p
                class="mb-2
                  text-[12px] text-red-400 font-mono
                  uppercase"
              >
                VLAN 12 / 13
              </p>
              <p
                class="font-bold text-red-100
                  uppercase italic"
              >
                Edificio West
              </p>
            </div>
            <div
              class="p-5
                bg-pink-900/10
                rounded-xl border border-pink-500/20"
            >
              <p
                class="mb-2
                  text-[12px] text-pink-400 font-mono
                  uppercase"
              >
                VLAN 22 / 23
              </p>
              <p
                class="font-bold text-pink-100
                  uppercase italic"
              >
                Edificio Ost
              </p>
            </div>
            <div
              class="p-5
                bg-emerald-900/10
                rounded-xl border border-emerald-500/20"
            >
              <p
                class="mb-2
                  text-[12px] text-emerald-400 font-mono
                  uppercase"
              >
                VLAN 99
              </p>
              <p
                class="font-bold text-emerald-100
                  uppercase italic"
              >
                Servidores
              </p>
            </div>
          </div>

          <div
            class="p-8
              bg-blue-900/10
              rounded-3xl border border-blue-500/20"
          >
            <h3
              class="mb-4
                text-lg font-bold text-blue-400
                uppercase italic"
            >
              Especificaciones Core:
            </h3>
            <ul
              class="space-y-3
                text-sm leading-relaxed text-slate-400
                italic"
            >
              <li class="flex
                  items-center gap-3">
                <span
                  class="w-2 h-2
                    bg-blue-500
                    rounded-full"
                ></span>
                <strong>Puertos Core:</strong> Uso exclusivo de <span
                  class="text-white font-mono">GigabitEthernet</span
                > para interconexión entre Switches 3560 y Routers.
              </li>
              <li class="flex
                  items-center gap-3">
                <span
                  class="w-2 h-2
                    bg-blue-500
                    rounded-full"
                ></span>
                <strong>Puertos Acceso:</strong> Uso de <span
                  class="text-white font-mono">FastEthernet</span
                > para Laptops y Switches 2960.
              </li>
            </ul>
          </div>
        </section>
        

        <section id="seguridad" class="mb-32">
          <h2
            class="mb-8 pl-4
              text-3xl font-bold text-white
              border-l-4 border-blue-500
              uppercase"
          >
            02. Configuración Base y Seguridad (Todos)
          </h2>
          <div
            class="overflow-hidden
              font-mono text-sm
              bg-[#0a0f1e]
              rounded-2xl border border-white/10
              shadow-2xl"
          >
            <div
              class="flex
                px-4 py-2
                bg-white/5
                border-b border-white/10
                justify-between"
            >
              <span
                class="text-xs text-slate-500 tracking-tighter
                  uppercase italic"
                >IOS CLI — Security & VTY Setup</span
              >
              <div class="flex
                  gap-2">
                <div
                  class="w-2 h-2
                    bg-red-500/50
                    rounded-full"
                >
                </div>
                <div
                  class="w-2 h-2
                    bg-green-500/50
                    rounded-full"
                >
                </div>
              </div>
            </div>
            <div class="overflow-x-auto p-8 text-white-300 leading-relaxed">
              <p>enable</p>
              <p>configure terminal</p>
              <p>hostname [Device_Name]</p>
              <p>ip domain-name lab.test</p>
              <p>no ip domain-lookup</p>
              <br />
              <p>username cisco privilege 15 secret cisco</p>
              <p>enable secret cisco</p>
              <p>service password-encryption</p>
              <br />
              <p>banner motd # ZUTRITT NUR FÜR BEFUGTE PERSONEN #</p>
              <br />
              <p>access-list 10 permit 10.0.8.0 0.0.0.255</p>
              <br />
              <p>line console 0</p>
              <p class="pl-4">exec-timeout 0 0</p> <p class="pl-4">logging synchronous</p>
              <p class="pl-4">login</p>
              <p class="pl-4">exit</p>
              <br />
              <p>line vty 0 15</p>
              <p class="pl-4">exec-timeout 0 0</p>
              <p class="pl-4">login local</p>
              <p class="pl-4">transport input ssh</p>
              <p class="pl-4">access-class 10 in</p>
              <p class="pl-4">exit</p>
              <br />
              <p>logging buffered 8192</p>
              <p class="text-orange-400/80 italic text-[13px] mb-1">
              // Nota: En Edificio Ost, invertir el orden (Primero Server Ost, luego West)
              </p>
              <p>logging host [IP Servidor West]</p> 
              <p>logging host [IP Servidor Ost]</p> 
              <p>logging trap debugging</p>
              <p>logging source-interface vlan 8</p>
              <p>crypto key generate rsa</p>
              <p>ip ssh version 2</p>
            </div>
          </div>
        </section>

        <section id="acceso" class="mb-32">
          <h2
            class="mb-10 pl-4
              text-3xl font-bold text-white tracking-tighter
              border-l-4 border-blue-500
              uppercase"
          >
            03. Configuración de Switches de Acceso (2960 - L2)
          </h2>

          <div class="grid
              gap-8
              lg:grid-cols-2">
            <div
              class="p-8
                bg-slate-900/50
                rounded-3xl border border-white/5
                shadow-2xl"
            >
              <h3
                class="mb-6
                  text-xl font-bold text-blue-500
                  uppercase"
              >
                SWITCH EV-L <span class="text-white font-medium">(WEST)</span>
              </h3>

              <div
                class="space-y-8
                  font-mono text-[12px] leading-relaxed"
              >
                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Creación VLANs
                  </p>
                  <div
                    class="overflow-x-auto
                      p-4
                      leading-relaxed
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>vlan 8 name Management</p>
                    <p>vlan 13 name West_Azul</p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Seguridad de Puertos
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>interface range fa0/1 - 24</p>
                    <p class="pl-4">switchport mode access</p>
                    <p class="pl-4">switchport access vlan 13</p>
                    <p class="pl-4">spanning-tree portfast</p>
                    <p class="pl-4">switchport port-security</p>
                    <p class="pl-4">switchport port-security maximum 2</p>
                    <p class="pl-4">
                      switchport port-security mac-address sticky
                    </p>
                    <p class="pl-4">
                      switchport port-security violation shutdown
                    </p>
                    <p class="pl-4">spanning-tree bpduguard enable</p>
                    <p>exit</p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Enlaces Troncales y Gestión
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>interface gig0/1</p>
                    <p class="pl-4">description Hauptlink_zu_GV-L</p>
                    <p class="pl-4">switchport mode trunk</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p>interface gig0/2</p>
                    <p class="pl-4">description Hauptlink_zu_GV-R</p>
                    <p class="pl-4">switchport mode trunk</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p>interface vlan 8</p>
                    <p class="pl-4">ip address 10.0.8.11 255.255.255.0</p>
                    <p class="pl-4">no shut</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p class="font-bold">ip default-gateway 10.0.8.1</p>
                  </div>
                </div>
              </div>
            </div>

            <div
              class="p-8
                bg-slate-900/50
                rounded-3xl border border-white/5
                shadow-2xl"
            >
              <h3
                class="mb-6
                  text-xl font-bold text-blue-500
                  uppercase"
              >
                SWITCH EV-R <span
                  class="text-white font-normal
                    not-italic"
                  >(OST)</span
                >
              </h3>

              <div
                class="space-y-8
                  font-mono text-[12px] leading-relaxed"
              >
                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Creación VLANs
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>vlan 8 name Management</p>
                    <p>vlan 23 name Ost_Lila</p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Seguridad de Puertos
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>interface range fa0/1 - 24</p>
                    <p class="pl-4">switchport mode access</p>
                    <p class="pl-4">switchport access vlan 23</p>
                    <p class="pl-4">spanning-tree portfast</p>
                    <p class="pl-4">switchport port-security</p>
                    <p class="pl-4">switchport port-security maximum 2</p>
                    <p class="pl-4">
                      switchport port-security mac-address sticky
                    </p>
                    <p class="pl-4">
                      switchport port-security violation shutdown
                    </p>
                    <p class="pl-4">spanning-tree bpduguard enable</p>
                    <p>exit</p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Enlaces Troncales y Gestión
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>interface gig0/1</p>
                    <p class="pl-4">description Hauptlink_zu_GV-R</p>
                    <p class="pl-4">switchport mode trunk</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p>interface gig0/2</p>
                    <p class="pl-4">description Hauptlink_zu_GV-L</p>
                    <p class="pl-4">switchport mode trunk</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p>interface vlan 8</p>
                    <p class="pl-4">ip address 10.0.8.22 255.255.255.0</p>
                    <p class="pl-4">no shut</p>
                    <p class="pl-4">exit</p>
                    <br/>
                    <p class="font-bold">ip default-gateway 10.0.8.1</p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </section>

        <section id="nucleo" class="mb-32">
          <h2
            class="mb-10 pl-4
              text-3xl font-bold text-white tracking-tighter
              border-l-4 border-blue-500
              uppercase"
          >
            04. Configuración del Núcleo (3560 - Capa 3)
          </h2>

          <div class="grid
              gap-8
              lg:grid-cols-2">
            <div
              class="p-8
                bg-slate-900/50
                rounded-3xl border border-white/5
                shadow-2xl"
            >
              <h3
                class="mb-6
                  text-xl font-bold text-blue-500
                  uppercase"
              >
                SWITCH GV-L <span class="text-white font-medium">(WEST)</span>
              </h3>

              <div
                class="space-y-8
                  font-mono text-[12px] leading-relaxed"
              >
                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Activación L3 y VLANs
                  </p>
                  <div
                    class="p-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <p>ip routing</p>
                    <p>vlan 8 name Management</p>
                    <p
                      class="text-slate-500 font-sans
                        italic"
                    >
                      // Crear también vlan 12, 13, 22, 23, 99
                    </p>
                  </div>
                </div>

                <div>
                  <p
                    class="mb-2
                      text-emerald-400 font-bold tracking-widest
                      uppercase italic underline decoration-emerald-500/30"
                  >
                    // Gateways (SVIs) y HSRP (Hot Standby Router Protocol)
                  </p>
                  <div
                    class="p-4 space-y-4
                      text-blue-100
                      bg-black/40
                      rounded-xl border border-white/5 text-sm"
                  >
                    <div>
                      <p class="text-slate-500
                          italic">
                        // VLAN 12 & 13 (Principales en West - G=1)
                      </p>
                      <p class="text-red-400">interface vlan 12</p>
                      <p class="pl-4">ip address 10.1.12.2 255.255.255.0</p>
                      <p class="pl-4">standby 12 ip 10.1.12.1</p>
                      <p class="pl-4">standby 12 priority 110</p>
                      <p class="pl-4">standby 12 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>
                      <br />
                      <p class="text-red-400">interface vlan 13</p>
                      <p class="pl-4">ip address 10.1.13.2 255.255.255.0</p>
                      <p class="pl-4">standby 13 ip 10.1.13.1</p>
                      <p class="pl-4">standby 13 priority 110</p>
                      <p class="pl-4">standby 13 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>
                    </div>
                    <div>
                      <p class="text-slate-500 italic"> // VLAN 22 & 23 (Respaldos Ost)</p>
                      <p class="text-pink-400">interface vlan 22</p>
                      <p class="pl-4">ip address 10.2.22.3 255.255.255.0</p>
                      <p class="pl-4">standby 22 ip 10.2.22.1</p>
                      <p class="pl-4">standby 22 priority 100</p>
                      <p class="pl-4">standby 22 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>
                      <br />
                      <p class="text-pink-400">interface vlan 23</p>
                      <p class="pl-4">ip address 10.2.23.3 255.255.255.0</p>
                      <p class="pl-4">standby 23 ip 10.2.23.1</p>
                      <p class="pl-4">standby 23 priority 100</p>
                      <p class="pl-4">standby 23 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>                      
                      <br />
                      <p class="text-slate-500 italic"> // Red interna de gestión</p>
                      <p class="text-blue-400">interface vlan 8 <span class="text-black/40">h</span></p>
                      <p class="pl-4">ip address 10.0.8.2 255.255.255.0</p>
                      <p class="pl-4">standby 8 ip 10.0.8.1</p>
                      <p class="pl-4">standby 8 priority 110</p>
                      <p class="pl-4">standby 8 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>
                      <br />
                      <p class="text-slate-500 italic"> // Red interna de servidores</p>
                      <p class="text-emerald-400">interface vlan 99</p>
                      <p class="pl-4 italic">ip address 10.0.99.2 255.255.255.0</p>
                      <p class="pl-4">standby 99 ip 10.0.99.1</p>
                      <p class="pl-4">standby 99 priority 110</p>
                      <p class="pl-4">standby 99 preempt</p>
                      <p class="pl-4">no shut</p>
                      <p class="pl-4">exit</p>
                    </div>
                  </div>
                </div>

                <div>
