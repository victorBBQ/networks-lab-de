<script>
  // 1. Definimos las razones de los comandos aquí (Mantenemos tu estructura funcional)
  const reasons = {
    // SEGURIDAD DE PUERTOS
    "spanning-tree portfast": "Evita esperas de 30s en el puerto; permite que la laptop reciba IP de inmediato al conectarse sin pasar por estados de escucha de STP.",
    "switchport port-security": "Activa la restricción de acceso físico; impide que cualquier dispositivo no autorizado pueda transmitir datos por este puerto.",
    "switchport port-security maximum 2": "Permite un máximo de 2 MACs (ej. Laptop y Teléfono IP) para evitar que alguien conecte un switch o hub pirata y amplíe la red.",
    "switchport port-security mac-address sticky": "El switch memoriza la MAC del trabajador y la guarda en la configuración; así solo ese equipo podrá usar ese puerto permanentemente.",
    "switchport port-security violation shutdown": "Medida de seguridad reactiva: si se detecta un intruso, el puerto se apaga físicamente y requiere intervención de IT para reactivarse.",
    "spanning-tree bpduguard enable": "Protege la red de bucles accidentales; si alguien conecta otro switch en la oficina, el puerto se bloquea para evitar una caída total de la red.",

    // REDUNDANCIA Y GATEWAYS (HSRP)
    "standby 12 ip 10.0.12.1": "Crea la 'IP Fantasma' que los usuarios ven como gateway; permite que la red siga funcionando aunque uno de los switches principales falle.",
    "standby 12 preempt": "Permite que el switch recupere su rol de líder automáticamente tras ser reparado o reiniciado, manteniendo el diseño de red original.",
    "standby 12 priority 110": "Se elige 110 porque supera el valor por defecto (100). Esto garantiza que este switch sea el 'Active' y procese todo el tráfico de esta VLAN en condiciones normales.",
    "standby 13 priority 110": "Se usa 110 para forzar la maestría sobre la VLAN 13, asegurando que el edificio tenga un camino determinista hacia el núcleo.",
    "standby 22 priority 110": "Establece a este switch como principal para la VLAN 22; se usa un valor mayor a 100 para evitar que la elección sea aleatoria o basada en la IP más alta.",
    "standby 23 priority 110": "Prioridad superior para asegurar que este equipo gestione el tráfico inalámbrico y de usuarios del edificio Ost de manera preferente.",

    "standby 12 priority 100": "Se mantiene en 100 (valor por defecto) para que actúe como switch de respaldo (Standby). Solo asumirá el control si el switch principal (110) deja de responder.",
    "standby 13 priority 100": "Configuración de respaldo: al ser menor que 110, este equipo permanece en espera, ahorrando recursos y manteniendo la jerarquía de la red.",
    "standby 22 priority 100": "Define a este equipo como el segundo al mando para la VLAN 22; garantiza continuidad del servicio si el switch principal de Ost falla.",
    "standby 23 priority 100": "Valor de prioridad estándar para el rol de redundancia; asegura que haya un camino de salida alternativo listo para activarse instantáneamente.",
    "standby 99 priority 110": "Se asigna 110 para designar a este switch como el 'Gateway Activo'. Al tener una prioridad superior al valor predeterminado, obligamos a que todo el tráfico que entra y sale de los servidores sea procesado por este equipo específicamente.",
    "standby 99 priority 100": "Se establece en 100 para definir el rol de 'Standby' (Respaldo). Este switch monitorea al principal y solo asumirá la carga de la VLAN 99 si detecta que el switch con prioridad 110 ha quedado fuera de servicio, garantizando alta disponibilidad.",

    // ACL SEGURIDAD SERVIDORES
    "ip access-list extended SERVER_SECURITY": "Define un filtro granular para proteger los servidores; evita que usuarios comunes vean datos sensibles, permitiendo solo a los administradores.",
    "permit ip 10.0.8.0 0.0.0.255 10.0.99.0 0.0.0.255": "Garantiza que solo el personal de Gestión (VLAN 8) pueda entrar a configurar o dar mantenimiento a los servidores.",
    "deny ip 10.0.0.0 0.0.255.255 10.0.99.0 0.0.0.255": "Bloquea proactivamente a todos los demás edificios y usuarios de la red para que no puedan atacar o acceder a los servidores.",
    "permit ip any any": "Línea vital que permite que el tráfico general (como la navegación a Internet) siga funcionando después de haber filtrado el acceso a los servidores.",

    // ETHERCHANNEL (LACP)
    "channel-group 1 mode active": "Agrupa dos cables físicos Gigabit en un solo canal lógico de 2Gbps, aumentando el ancho de banda y eliminando cuellos de botella entre edificios.",
    "interface port-channel 1": "Crea la interfaz virtual que gestiona el grupo de cables; simplifica la configuración de seguridad y enrutamiento entre los dos switches core. Se configura como un enlace de alta capacidad (LACP) para soportar el tráfico inter-edificio.",
    "ip address 10.0.99.1 255.255.255.252": "Asigna una red punto a punto al enlace entre edificios para permitir que el tráfico fluya directamente sin pasar por los routers de salida.",

    // ENCAPSULAMIENTO
    "switchport trunk encapsulation dot1q": "Prepara el puerto para entender etiquetas VLAN; es el estándar necesario antes de poder transportar múltiples redes por un solo cable físico.",
    "switchport mode trunk": "Convierte el puerto en una 'supercarretera' que transporta datos de todas las VLANs (Gestión, West, Ost, Servidores) simultáneamente.",

    // EL PORQUÉ DEL IP HELPER
    "ip helper-address 10.0.99.2": "Se usa porque las peticiones DHCP son 'broadcast' y los routers/switches L3 las bloquean por defecto. Sin este comando, las laptops nunca alcanzarían al servidor DHCP que está en otra VLAN o edificio, quedando sin internet.",

    // 2. EL PORQUÉ DE RIP V2 (Sección 05)
    "router rip": "Se implementa para que la red sea autónoma; si un enlace se cae, los routers calculan una ruta alternativa en segundos sin intervención humana.",
    "version 2": "Es obligatoria para redes modernas porque permite VLSM (subredes de distinto tamaño), lo que evita el desperdicio masivo de direcciones IP que ocurría en la versión 1.",
    "network 10.0.0.0": "Agrupa toda la infraestructura bajo un solo anuncio; permite que cualquier VLAN nueva que crees sea conocida por el resto de la red automáticamente.",
    "default-information originate (Aplicar solo en Routers)": "Evita tener que configurar rutas manualmente en cada switch; el router 'le cuenta' a toda la red interna que él es la salida oficial a Internet.",
    "no auto-summary": "Vital para que la red no colapse; impide que RIP confunda la VLAN 12 con la 22 al intentar resumirlas, permitiendo que cada edificio mantenga su identidad.",
    
    // RUTAS ESTÁTICAS Y RESPALDOS
    "ip route 10.0.22.0 255.255.255.0 10.0.99.2": "Establece un 'atajo' directo entre edificios a través del EtherChannel; así el tráfico local no tiene que subir hasta los routers de internet, optimizando la velocidad.",
    "ip route 10.0.23.0 255.255.255.0 10.0.99.2": "Garantiza que la comunicación entre departamentos de distintos edificios sea privada y no dependa de la conexión externa del ISP.",
    "ip route 10.0.13.0 255.255.255.0 10.0.99.2 20 (Falla)": "Es el seguro de vida de los datos; si el switch principal de un edificio falla, el tráfico se desvía por el vecino para mantener a los usuarios conectados.",
    "ip route 0.0.0.0 0.0.0.0 10.0.1.1 10 // Vía Router 1 - Principal": "Es la salida principal. El número '10' es la Distancia Administrativa; se pone baja para que el switch siempre prefiera este camino mientras el Router 1 esté vivo.",
    "ip route 0.0.0.0 0.0.0.0 10.0.99.2 50 // Vía Router 2 - Respaldo": "Es una 'Ruta Flotante'. Al tener prioridad 50 (peor que 10), permanece invisible. Solo se activa si el enlace principal muere, garantizando que la empresa nunca se quede sin internet.",
    // NAT Y ROUTERS
    "ip nat inside": "Marca la interfaz que da hacia la empresa; le dice al router que los paquetes que entren por aquí deben ser traducidos para poder salir a internet.",
    "ip nat outside": "Marca la interfaz que da al mundo exterior; indica que aquí es donde termina la red privada y comienza la conexión pública del ISP.",
    "ip route 10.0.0.0 255.255.0.0 10.0.1.2": "Crucial para el retorno: indica al router que los datos que vienen de internet deben enviarse de vuelta al switch core para llegar a las laptops.",
    "access-list 1 permit 10.0.0.0 0.0.255.255": "Define el grupo de confianza: especifica qué dispositivos internos tienen permiso para que el router les preste su IP pública para navegar.",
    "ip nat inside source list 1 [interfaz_internet] overload": "Activa PAT (Port Address Translation): permite que cientos de empleados compartan una sola IP pública de forma segura y eficiente."
  };

  // 2. Lógica para mostrar el popup (Exactamente tu código original)
  const tooltip = document.createElement('div');
  tooltip.className = 'fixed hidden z-50 p-3 bg-slate-800 border border-emerald-500/50 text-emerald-400 text-xs rounded-lg shadow-2xl max-w-xs italic pointer-events-none';
  document.body.appendChild(tooltip);

  // Seleccionamos todos los párrafos dentro de tus cuadros de código
  document.querySelectorAll('div[class*="bg-black/40"] p').forEach(p => {
    const command = p.innerText.trim();
    
    if (reasons[command]) {
      p.classList.add('cursor-help', 'hover:text-emerald-400', 'transition-colors');
      
      p.addEventListener('mouseenter', (e) => {
        tooltip.innerHTML = `<strong class="block text-white not-italic mb-1 uppercase text-[10px]">¿Por qué?</strong>${reasons[command]}`;
        tooltip.classList.remove('hidden');
      });

      p.addEventListener('mousemove', (e) => {
        tooltip.style.left = (e.clientX + 15) + 'px';
        tooltip.style.top = (e.clientY + 15) + 'px';
      });

      p.addEventListener('mouseleave', () => {
        tooltip.classList.add('hidden');
      });
    }
  });
</script>