---
const { reason } = Astro.props;
---
<span class="group relative inline-block">
  <span class="text-blue-100 border-b border-blue-500/30 hover:border-blue-400 cursor-help transition-colors">
    <slot />
  </span>
  
  <span class="absolute bottom-full left-1/2 -translate-x-1/2 mb-2 w-64 p-3 
               bg-[#0f172a] text-emerald-400 text-[11px] font-sans normal-case italic
               rounded-lg border border-emerald-500/30 shadow-2xl 
               opacity-0 group-hover:opacity-100 transition-all pointer-events-none z-50
               leading-relaxed text-center">
    <span class="block text-white font-bold mb-1 uppercase text-[9px] tracking-widest">¿Por qué se usa?</span>
    {reason}
    <span class="absolute top-full left-1/2 -translate-x-1/2 border-8 border-transparent border-t-[#0f172a]"></span>
  </span>
</span>